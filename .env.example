# ==================================================================
# WhiskyFest Contracts — Environment Variables
# Copy this file to .env.local for local dev; set these in Vercel
# for production.
# ==================================================================

# --- NextAuth ---
# Run: openssl rand -base64 32
AUTH_SECRET=
# For local dev: http://localhost:3000
# For production: https://whiskyfest-contracts.vercel.app
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth (for login) ---
# console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client ID, web application
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Supabase ---
# supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Service role key — SERVER ONLY, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Drive/Docs (for PDF generation) ---
# Create a service account at console.cloud.google.com
# Enable Drive API + Docs API
# Download JSON key, then base64-encode it:
#   base64 -i service-account-key.json | pbcopy    (macOS)
#   base64 service-account-key.json                 (Linux)
# Share the template Doc and Drafts/Signed folders with the service
# account's email (found in the JSON client_email field)
GOOGLE_SERVICE_ACCOUNT_KEY=

# The master contract template Google Doc ID (from the URL)
GOOGLE_TEMPLATE_DOC_ID=1W5wJvMPZUlHfIkZ7yscYBFQrVATzrvwNhHTNrupeQP4

# Drive folder IDs
GOOGLE_DRAFTS_FOLDER_ID=1gZYxZvsR9VJuNTVOKBxPdFnkAquLmMGT
GOOGLE_SIGNED_FOLDER_ID=1scV2YZ963-Y9M2RAN876q3J1t_PAz_Ew

# --- DocuSign (Phase 2 — leave blank for Phase 1) ---
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_AUTH_URL=https://account-d.docusign.com
DOCUSIGN_RSA_PRIVATE_KEY=

# --- Email (Phase 2 — accounting notifications) ---
SENDGRID_API_KEY=
ACCOUNTING_EMAIL=accounting@mshanken.com
